{
    // ── CMake 配置 ────────────────────────────────────────
    "cmake.buildDirectory":    "${workspaceFolder}/build_${buildType}",
    "cmake.generator":         "Unix Makefiles",
    "cmake.configureArgs": [
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
        "-DENABLE_TESTS=OFF",
        "-DENABLE_MLX5=OFF"
    ],
    "cmake.buildArgs": [
        "--parallel",
        "--",
        "-j16"
    ],

    // ── 默认构建类型 ──────────────────────────────────────
    "cmake.defaultVariants": {
        "buildType": {
            "default": "release",
            "choices": {
                "debug": {
                    "short":         "Debug",
                    "long":          "Debug build with symbols",
                    "buildType":     "Debug",
                    "settings": {
                        "ENABLE_ASAN": "ON"
                    }
                },
                "release": {
                    "short":         "Release",
                    "long":          "Optimized release build",
                    "buildType":     "Release"
                },
                "relwithdebinfo": {
                    "short":         "RelWithDebInfo",
                    "long":          "Release with debug info",
                    "buildType":     "RelWithDebInfo"
                }
            }
        }
    },

    // ── C/C++ 通用设置 ────────────────────────────────────
    "C_Cpp.default.cppStandard":         "c++17",
    "C_Cpp.default.cStandard":           "c11",
    "C_Cpp.default.intelliSenseMode":    "linux-gcc-x64",
    // 使用 compile_commands.json（CMake生成）
    "C_Cpp.default.compileCommands":
        "${workspaceFolder}/build_Release/compile_commands.json",

    // ── clangd 配置（如果安装了clangd插件）──────────────
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build_Release",
        "--background-index",
        "--clang-tidy",
        "--header-insertion=never",
        "--completion-style=detailed",
        "--function-arg-placeholders=false"
    ],
    // clangd 与 C/C++ 插件二选一，避免冲突
    "C_Cpp.intelliSenseEngine": "disabled",

    // ── 编辑器设置 ────────────────────────────────────────
    "editor.formatOnSave":               true,
    "editor.tabSize":                    4,
    "editor.insertSpaces":               true,
    "editor.rulers":                     [100],
    "editor.renderWhitespace":           "trailing",
    "files.trimTrailingWhitespace":      true,
    "files.insertFinalNewline":          true,
    "files.encoding":                    "utf8",

    // ── 文件关联 ──────────────────────────────────────────
    "files.associations": {
        "*.h":   "cpp",
        "*.hpp": "cpp",
        "*.cpp": "cpp"
    },

    // ── 排除不需要的目录（加快文件扫描）─────────────────
    "files.exclude": {
        "**/build_*":     true,
        "**/.git":        true,
        "**/CMakeFiles":  true,
        "**/*.o":         true,
        "**/*.a":         true
    },

    // ── 终端配置（远程终端用bash）─────────────────────────
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.scrollback":           10000
}